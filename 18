 #define MAX 100
 int findLRU(int time[], int n) {
 int min = time[0], minIndex = 0;
 for (int i = 1; i < n; i++) {
 if (time[i] < min) {
 min = time[i];
 minIndex = i;
 }
 }
 return minIndex;
 }
