 #include <stdio.h>
 #include <stdlib.h>
 #include <string.h>
 #include <unistd.h>
 #include <sys/wait.h>
 #define MAX_CMD_LEN 1024
 #define MAX_ARGS 100
 void typeline_all(char *filename) {
 FILE *file = fopen(filename, "r");
 char line[256];
 if (file == NULL) {
 perror("myshell");
 return;
 }
 while (fgets(line, sizeof(line), file)) {
 printf("%s", line);
 }
 fclose(file);
 }
 void execute_command(char **args) {
 pid_t pid = fork();
 if (pid < 0) {
 perror("myshell");
 } else if (pid == 0) { 
 if (execvp(args[0], args) ==-1) {
perror("myshell");
 }
 exit(EXIT_FAILURE);
 } else { 
 wait(NULL);
 }
 }
 int main() {
 char command[MAX_CMD_LEN];
 char *args[MAX_ARGS];
 char *token;
 int should_run = 1;
 while (should_run) {
 printf("myshell$ ");
 fgets(command, MAX_CMD_LEN, stdin);
 command[strlen(command)-1] = '\0'; 
 int arg_count = 0;
 token = strtok(command, " ");
 while (token != NULL) {
 args[arg_count++] = token;
 token = strtok(NULL, " ");
 }
 args[arg_count] = NULL;
 if (arg_count == 0) {
 continue; 
 }
 if (strcmp(args[0], "exit") == 0) {
 should_run = 0;
 }
 else if (strcmp(args[0], "typeline") == 0 && arg_count == 3 &&
 strcmp(args[1], "-a") == 0) {
 typeline_all(args[2]);
 }
 else {
 execute_command(args);
 }
 }
 return 0
 }

