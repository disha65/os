#include<stdio.h>
#include<sys/types.h>
#define MAX 20

void readarray(int a[],int n)
{
	int i;
	printf("\nEnter data for array:");
	for(i=0;i<n;i++)
		scanf("%d",&a[i]);
}

void printarray(int a[],int n)
{
	int i;
	for(i=0;i<n;i++)
		printf("%d\t",a[i]);
}

void bubblesort(int a[],int n)
{
    int i,j,t;
    for(i=1;i<n;i++)
    {
        for(j=0;j<n-i;j++)
        {
             if(a[j]>a[j+1]) 
             {
                t=a[j];
                a[j]=a[j+1];
                a[j+1]=t;
              }
        }      
	}
}

void insertionsort(int a[],int n)
{
	int i,j,t;
	for(i=1;i<n;i++)
	{
		t = a[i];
		
		for(j=i-1;j>=0;j--)
		{
			if(a[j]>t)
				a[j+1] = a[j];
		    else
		        break;
		}
		a[j+1] = t;
	}
}

int main()
{
	int a[MAX],n;
	int i;
	
	printf("\nEnter how many numbers you want:");
	scanf("%d",&n);

	printf("\nEnter data for your array");
	readarray(a,n);
	
	printf("\nYour array before sort\n");
	printarray(a,n);
	
	if(fork()==0)
	{
		printf("\nI am child Process\n");
		insertionsort(a,n);
		printf("\nArray sorted by Child Process");
		printarray(a,n);
	}
	else
	{
		printf("\nI am Parent Process\n");
		bubblesort(a,n);
		printf("\nArray sorted by Parent Process");
		printarray(a,n);
	}
	return 0;
}

