 void list_files(const char *dirname) {
 struct dirent *entry;
 DIR *dp = opendir(dirname);
 if (dp == NULL) return;
 while ((entry = readdir(dp)) != NULL) {
 if (entry->d_name[0] != '.') {
 printf("%s\n", entry->d_name);
 }
 }
 closedir(dp);
 }
 void list_count(const char *dirname) {
 struct dirent *entry;
 DIR *dp = opendir(dirname);
 int count = 0;
